{
  "compilerOptions": {
    "target":           "ES2022",
    "module":           "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir":          "./",
    "outDir":           "./dist",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "express.d.ts",
    "index.ts",
    "types.ts",
    "config/**/*.ts",
    "middleware/**/*.ts",
    "routes/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "seed.ts",
    "setup.ts"
  ]
}